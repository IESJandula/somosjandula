# Desarrollo local: cada microservicio se sirve en localhost:PUERTO.
# VITE_ENVIRONMENT=development (ni 'pre' ni 'pro') hace que apiUrls.ts use estas
# URLs explícitas en lugar de derivar hosts pro/pre.
VITE_ENVIRONMENT=development
