VITE_ISSUES_API_BASE_URL=http://localhost:8085
VITE_SCHOOLMANAGER_API_BASE_URL=http://localhost:8087
VITE_NOTIFICATIONS_API_BASE_URL=http://localhost:8088
VITE_EVENTS_API_BASE_URL=http://localhost:8089
VITE_STRIKES_API_BASE_URL=http://localhost:8091
VITE_AUTOMATIONS_API_BASE_URL=http://localhost:8092
VITE_IMAGES_CLONER_API_BASE_URL=http://localhost:8094
VITE_AUDIT_API_BASE_URL=http://localhost:8095